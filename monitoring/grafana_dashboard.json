{
  "title": "DermAI — Skin Disease Detection Dashboard",
  "uid": "dermai-main",
  "tags": ["dermai", "mlops", "da5402"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Model Status",
      "gridPos": {"x":0,"y":0,"w":3,"h":4},
      "targets": [{"expr": "model_loaded", "legendFormat": ""}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {"steps": [{"color":"red","value":0},{"color":"green","value":1}]}
      }
    },

    {
      "id": 2, "type": "stat", "title": "MongoDB Status",
      "gridPos": {"x":3,"y":0,"w":3,"h":4},
      "targets": [{"expr": "mongodb_up", "legendFormat": ""}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {"steps": [{"color":"red","value":0},{"color":"green","value":1}]}
      }
    },

    {
      "id": 3, "type": "stat", "title": "Total Predictions",
      "gridPos": {"x":6,"y":0,"w":3,"h":4},
      "targets": [{"expr": "unique_predictions_total", "legendFormat": ""}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },

    {
      "id": 4, "type": "stat", "title": "API Uptime",
      "gridPos": {"x":9,"y":0,"w":3,"h":4},
      "targets": [{"expr": "api_uptime_seconds", "legendFormat": ""}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "unit": "s"}
    },

    {
      "id": 5, "type": "stat", "title": "Feedback Positive Rate",
      "gridPos": {"x":12,"y":0,"w":3,"h":4},
      "targets": [{"expr": "feedback_positive_rate", "legendFormat": ""}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "unit": "percentunit",
        "thresholds": {"steps": [{"color":"red","value":0},{"color":"yellow","value":0.5},{"color":"green","value":0.75}]}
      }
    },

    {
      "id": 6, "type": "stat", "title": "High Risk Predictions",
      "gridPos": {"x":15,"y":0,"w":3,"h":4},
      "targets": [{"expr": "high_risk_predictions_total", "legendFormat": ""}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {"steps": [{"color":"green","value":0},{"color":"orange","value":5},{"color":"red","value":20}]}
      }
    },

    {
      "id": 7, "type": "timeseries", "title": "Inference Latency (p50 / p95 / p99)",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(inference_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(inference_latency_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(inference_latency_seconds_bucket[5m]))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}}}
    },

    {
      "id": 8, "type": "timeseries", "title": "Request Rate by Endpoint",
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [
        {"expr": "rate(api_requests_total[5m])", "legendFormat": "{{endpoint}} {{method}} {{status_code}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },

    {
      "id": 9, "type": "piechart", "title": "Status Code Distribution",
      "gridPos": {"x":0,"y":12,"w":8,"h":8},
      "targets": [
        {"expr": "sum by (status_code) (api_requests_total)", "legendFormat": "{{status_code}}"}
      ],
      "options": {"pieType": "donut", "displayLabels": ["name","percent"]}
    },

    {
      "id": 10, "type": "piechart", "title": "Predictions by Disease Class",
      "gridPos": {"x":8,"y":12,"w":8,"h":8},
      "targets": [
        {"expr": "sum by (predicted_class) (predictions_total)", "legendFormat": "{{predicted_class}}"}
      ],
      "options": {"pieType": "donut", "displayLabels": ["name","percent"]}
    },

    {
      "id": 11, "type": "piechart", "title": "User Feedback — Like / Dislike",
      "gridPos": {"x":16,"y":12,"w":8,"h":8},
      "targets": [
        {"expr": "sum by (vote) (feedback_total)", "legendFormat": "{{vote}}"}
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name","value","percent"],
        "custom": {
          "thumbs_up"  : {"color": "#22c55e"},
          "thumbs_down": {"color": "#ef4444"}
        }
      }
    },

    {
      "id": 12, "type": "timeseries", "title": "System CPU %",
      "gridPos": {"x":0,"y":20,"w":8,"h":7},
      "targets": [
        {"expr": "system_cpu_percent", "legendFormat": "CPU %"},
        {"expr": "80", "legendFormat": "Warning threshold"},
        {"expr": "90", "legendFormat": "Critical threshold"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100},
        "overrides": [
          {"matcher":{"id":"byName","options":"Warning threshold"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}},{"id":"custom.lineStyle","value":{"dash":[8,4],"fill":"dash"}}]},
          {"matcher":{"id":"byName","options":"Critical threshold"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}},{"id":"custom.lineStyle","value":{"dash":[8,4],"fill":"dash"}}]}
        ]
      }
    },

    {
      "id": 13, "type": "timeseries", "title": "System Memory %",
      "gridPos": {"x":8,"y":20,"w":8,"h":7},
      "targets": [
        {"expr": "system_memory_percent", "legendFormat": "Memory %"},
        {"expr": "75", "legendFormat": "Warning threshold"},
        {"expr": "90", "legendFormat": "Critical threshold"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent", "min": 0, "max": 100},
        "overrides": [
          {"matcher":{"id":"byName","options":"Warning threshold"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"Critical threshold"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]
      }
    },

    {
      "id": 14, "type": "timeseries", "title": "GPU Memory (GB)",
      "gridPos": {"x":16,"y":20,"w":8,"h":7},
      "targets": [
        {"expr": "gpu_memory_allocated_gb", "legendFormat": "Allocated"},
        {"expr": "gpu_memory_reserved_gb",  "legendFormat": "Reserved"},
        {"expr": "30", "legendFormat": "Warning (30GB)"},
        {"expr": "40", "legendFormat": "Critical (40GB)"}
      ],
      "fieldConfig": {"defaults": {"unit": "decgbytes"}}
    },

    {
      "id": 15, "type": "timeseries", "title": "Per-Class Prediction F1 — Mistake % (from eval)",
      "gridPos": {"x":0,"y":27,"w":12,"h":8},
      "targets": [
        {"expr": "predictions_total", "legendFormat": "{{predicted_class}} — {{risk_level}}"}
      ],
      "description": "Live prediction distribution. For F1/mistake %, see eval_metrics.json logged in MLflow."
    },

    {
      "id": 16, "type": "timeseries", "title": "Confidence Score Distribution (median)",
      "gridPos": {"x":12,"y":27,"w":12,"h":8},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(prediction_confidence_bucket[10m]))", "legendFormat": "p50 confidence — {{predicted_class}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },

    {
      "id": 17, "type": "timeseries", "title": "Active Concurrent Requests",
      "gridPos": {"x":0,"y":35,"w":12,"h":6},
      "targets": [
        {"expr": "sum(active_requests)", "legendFormat": "Total active"},
        {"expr": "active_requests", "legendFormat": "{{endpoint}}"}
      ]
    },

    {
      "id": 18, "type": "timeseries", "title": "Error Rate by Type",
      "gridPos": {"x":12,"y":35,"w":12,"h":6},
      "targets": [
        {"expr": "rate(errors_total[5m])", "legendFormat": "{{error_type}} — {{endpoint}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "errps"}}
    },

    {
      "id": 19, "type": "timeseries", "title": "Image Processing Time by Stage",
      "gridPos": {"x":0,"y":41,"w":12,"h":6},
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(image_processing_duration_seconds_bucket[5m]))", "legendFormat": "p95 — {{stage}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },

    {
      "id": 20, "type": "timeseries", "title": "Request Memory Usage p95 (MB)",
      "gridPos": {"x":12,"y":41,"w":12,"h":6},
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(request_memory_usage_mb_bucket[5m]))", "legendFormat": "p95 memory — {{endpoint}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "decmbytes"}}
    },

    {
      "id": 21, "type": "alertlist", "title": "Active Alerts",
      "gridPos": {"x":0,"y":47,"w":24,"h":6},
      "options": {
        "alertName": "",
        "dashboardAlerts": false,
        "stateFilter": {"firing": true, "pending": true, "noData": false, "error": true}
      }
    }

  ],

  "annotations": {
    "list": [
      {
        "name": "Alerts",
        "enable": true,
        "datasource": "Prometheus",
        "expr": "ALERTS{alertstate='firing'}",
        "iconColor": "red"
      }
    ]
  }
}